# Higiene de cadena de suministro (supply chain).
#
# engine-strict: respeta el rango de Node declarado en package.json ("20.x").
# Evita instalar bajo una versión de Node distinta que podría resolver árboles
# de dependencias diferentes.
engine-strict=true

# save-exact: cuando se añade una dependencia nueva, la fija a versión exacta
# en package.json (sin "^"). Reduce la deriva silenciosa de versiones.
save-exact=true

# fund/audit ruido fuera de la salida de instalación (el audit real corre como
# gate en CI: .github/workflows/supply-chain.yml).
fund=false

# NOTA: NO se activa `ignore-scripts=true` globalmente. Bloquearía los scripts
# de instalación legítimos de dependencias nativas (esbuild, prisma engines),
# rompiendo el build. El blindaje contra postinstall maliciosos se hace con:
#   1) npm ci (instala exactamente el lockfile, no trae versiones nuevas)
#   2) cooldown de versiones en Dependabot (.github/dependabot.yml)
#   3) npm audit + audit signatures como gate en CI
