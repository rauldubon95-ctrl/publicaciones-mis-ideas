# Base de datos - Supabase PostgreSQL
# Ve a: https://supabase.com/dashboard → tu proyecto → Settings → Database
# Sección "Connection string" → URI (con password)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (para migraciones Prisma - misma sección, puerto 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Clave secreta para acceder al panel admin
ADMIN_SECRET="cambia-esta-clave-secreta-123"

# URL base de la aplicacion (sin barra al final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
