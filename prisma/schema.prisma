generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Publicacion {
  id            String    @id @default(cuid())
  titulo        String
  slug          String    @unique
  resumen       String
  contenido     String
  publicado     Boolean   @default(false)
  creadoAt      DateTime  @default(now())
  actualizadoAt DateTime  @updatedAt
  publicadoAt   DateTime?

  // Contenido premium (sesión 12)
  esPremium       Boolean @default(false)
  precioCentavos  Int?    // null si no es premium
  resumenPublico  String? // texto visible antes del muro de pago

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  etiquetas   PublicacionEtiqueta[]
  comentarios   Comentario[]
  reacciones    Reaccion[]
  vistas        VistaPublicacion[]
  descargas     DescargaPdf[]
  enviosEmail   EmailEnvio[]
  pedidos       PedidoContenido[]

  @@index([categoriaId])
}

model Categoria {
  id            String        @id @default(cuid())
  nombre        String        @unique
  slug          String        @unique
  descripcion   String?
  icono         String?       // Emoji o identificador de ícono (ej: "📚")
  imagen        String?       // URL de imagen representativa de la categoría
  publicaciones Publicacion[]
}

model Etiqueta {
  id            String                @id @default(cuid())
  nombre        String                @unique
  slug          String                @unique
  publicaciones PublicacionEtiqueta[]
}

model PublicacionEtiqueta {
  publicacionId String
  etiquetaId    String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  etiqueta      Etiqueta    @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([publicacionId, etiquetaId])
  @@index([etiquetaId])
}

model Comentario {
  id            String       @id @default(cuid())
  contenido     String
  autorNombre   String
  publicacionId String
  creadoAt      DateTime     @default(now())
  actualizadoAt DateTime     @updatedAt
  // Anidación
  parentId      String?
  parent        Comentario?  @relation("Respuestas", fields: [parentId], references: [id], onDelete: Cascade)
  respuestas    Comentario[] @relation("Respuestas")
  profundidad   Int          @default(0) // 0=raíz, 1=respuesta, 2=respuesta a respuesta
  // Autor
  esAdmin       Boolean      @default(false)
  // Moderación
  estado        String       @default("VISIBLE") // VISIBLE | OCULTO | ELIMINADO

  publicacion   Publicacion  @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@index([publicacionId])
  @@index([parentId])
  @@index([estado])
}

model Reaccion {
  id            String      @id @default(cuid())
  tipo          String
  publicacionId String
  sessionId     String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@unique([publicacionId, sessionId, tipo])
}

model VistaPublicacion {
  id            String      @id @default(cuid())
  publicacionId String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  pais          String?
  dispositivo   String?
  ipHash        String?
  creadoAt      DateTime    @default(now())

  @@index([publicacionId])
  @@index([creadoAt])
  @@index([pais])
  @@index([ipHash])
}

model VistaRecurso {
  id         String      @id @default(cuid())
  recursoId  String
  recurso    RecursoHtml @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  pais       String?
  dispositivo String?
  ipHash     String?
  creadoAt   DateTime    @default(now())

  @@index([recursoId])
  @@index([creadoAt])
  @@index([ipHash])
}

model VistaComic {
  id          String   @id @default(cuid())
  comicId     String
  comic       Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  pais        String?
  dispositivo String?
  ipHash      String?
  creadoAt    DateTime @default(now())

  @@index([comicId])
  @@index([creadoAt])
  @@index([ipHash])
}

model DescargaPdf {
  id            String      @id @default(cuid())
  publicacionId String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  pais          String?
  creadoAt      DateTime    @default(now())

  @@index([publicacionId])
  @@index([creadoAt])
}

model RecursoHtml {
  id            String         @id @default(cuid())
  titulo        String
  slug          String         @unique
  descripcion   String
  contenido     String
  publicado     Boolean        @default(false)
  creadoAt      DateTime       @default(now())
  actualizadoAt DateTime       @updatedAt
  // Recurso premium (Fase 4, sesión 17)
  esPremium      Boolean         @default(false)
  precioCentavos Int?            // null = sin precio; >0 = precio en USD centavos
  resumenPublico String?         // texto visible antes del muro (fallback a descripcion)
  vistas         VistaRecurso[]
  pedidos        PedidoRecurso[]

  @@index([slug])
}

model PedidoRecurso {
  id              String      @id @default(cuid())
  recursoId       String
  recurso         RecursoHtml @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  emailComprador  String
  nombreComprador String?
  montoCentavos   Int
  moneda          String      @default("USD")
  paypalOrderId   String?     @unique
  estado          String      @default("PENDIENTE") // PENDIENTE | COMPLETADO | CANCELADO | FALLIDO
  tokenAcceso     String      @unique @default(cuid())
  creadoAt        DateTime    @default(now())
  completadoAt    DateTime?
  ultimoAccesoAt  DateTime?
  descargas       Int         @default(0) // nº de descargas consumidas (tope anti-reshare; solo aplica a la descarga del archivo)
  expiraAccesoAt  DateTime?   // caducidad de la DESCARGA. null = legacy (sin caducidad). La lectura en pantalla no caduca.

  @@index([emailComprador])
  @@index([estado])
  @@index([recursoId, estado])
  @@index([creadoAt])
}

model Comic {
  id            String        @id @default(cuid())
  titulo        String
  slug          String        @unique
  descripcion   String
  publicado     Boolean       @default(false)
  creadoAt      DateTime      @default(now())
  actualizadoAt DateTime      @updatedAt
  paginas       PaginaComic[]
  vistas        VistaComic[]

  @@index([slug])
}

model PaginaComic {
  id       String  @id @default(cuid())
  comicId  String
  comic    Comic   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  imageUrl String
  orden    Int
  caption  String?

  @@index([comicId])
  @@index([comicId, orden])
}

// Registro persistente de eventos de seguridad
model EventoSeguridad {
  id       String   @id @default(cuid())
  tipo     String   // LOGIN_FALLIDO | RATE_LIMIT | BOT_DETECTADO | ACCESO_DENEGADO | SPAM | SCAN_PATH
  ip       String
  ruta     String?
  detalles String?
  creadoAt DateTime @default(now())

  @@index([tipo])
  @@index([ip])
  @@index([creadoAt])
}

// Rate limiting persistente (sobrevive cold starts en serverless)
model RateLimitDb {
  id             String    @id @default(cuid())
  clave          String    @unique // "ip:ruta"
  contador       Int       @default(1)
  resetAt        DateTime
  bloqueadoHasta DateTime?

  @@index([clave])
  @@index([resetAt])
}

// Servicios de consultoría
model Servicio {
  id            String                @id @default(cuid())
  titulo        String
  slug          String                @unique
  descripcion   String
  detalle       String?
  categoria     String
  icono         String?
  activo        Boolean               @default(true)
  orden         Int                   @default(0)
  creadoAt      DateTime              @default(now())
  actualizadoAt DateTime              @updatedAt
  cotizaciones  SolicitudCotizacion[]

  @@index([activo])
  @@index([orden])
  @@index([categoria])
}

// Solicitudes de cotización
model SolicitudCotizacion {
  id           String    @id @default(cuid())
  nombre       String
  correo       String
  organizacion String?
  servicioId   String?
  servicio     Servicio? @relation(fields: [servicioId], references: [id], onDelete: SetNull)
  tipoServicio String?
  descripcion  String
  presupuesto  String?
  estado       String    @default("PENDIENTE") // PENDIENTE | REVISADO | RESPONDIDA | ARCHIVADO
  ipHash       String?
  creadoAt     DateTime  @default(now())
  respondidaAt DateTime?
  respuestas   RespuestaCotizacion[]

  @@index([servicioId])
  @@index([estado])
  @@index([creadoAt])
}

// Historial de respuestas enviadas por el admin a una cotización (Fase 3).
// Máximo 5 respuestas por cotización — enforce en API (sin trigger).
model RespuestaCotizacion {
  id              String              @id @default(cuid())
  cotizacionId    String
  cotizacion      SolicitudCotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  asunto          String
  cuerpoHtml      String
  cuerpoTexto     String
  enviadoPor      String              // identificador del admin (mailbox o "admin")
  resendMessageId String?
  estadoEnvio     String              @default("PENDIENTE") // PENDIENTE | ENVIADO | FALLIDO
  errorMensaje    String?
  creadoAt        DateTime            @default(now())

  @@index([cotizacionId])
  @@index([estadoEnvio])
  @@index([creadoAt])
}

model Tablero {
  id            String   @id @default(cuid())
  titulo        String
  slug          String   @unique
  descripcion   String?
  categoria     String?
  archivoUrl    String   // URL pública en Supabase Storage
  archivoNombre String   // Nombre original del archivo .xlsx
  preview       String   @db.Text // JSON: {sheetName, headers, rows, totalRows}
  publicado     Boolean  @default(false)
  orden         Int      @default(0)
  creadoAt      DateTime @default(now())
  actualizadoAt DateTime @updatedAt
  // Tablero premium (Fase 5, sesión 17)
  esPremium      Boolean           @default(false)
  precioCentavos Int?              // null = sin precio; >0 = precio en USD centavos
  resumenPublico String?           // texto visible antes del muro (fallback a descripcion)
  pedidos        PedidoDashboard[]

  @@index([publicado, orden])
}

model PedidoDashboard {
  id              String    @id @default(cuid())
  tableroId       String
  tablero         Tablero   @relation(fields: [tableroId], references: [id], onDelete: Cascade)
  emailComprador  String
  nombreComprador String?
  montoCentavos   Int
  moneda          String    @default("USD")
  paypalOrderId   String?   @unique
  estado          String    @default("PENDIENTE") // PENDIENTE | COMPLETADO | CANCELADO | FALLIDO
  tokenAcceso     String    @unique @default(cuid())
  creadoAt        DateTime  @default(now())
  completadoAt    DateTime?
  ultimoAccesoAt  DateTime?
  descargas       Int       @default(0) // nº de descargas consumidas (tope anti-reshare; solo aplica a la descarga del archivo)
  expiraAccesoAt  DateTime? // caducidad de la DESCARGA. null = legacy (sin caducidad). La lectura en pantalla no caduca.

  @@index([emailComprador])
  @@index([estado])
  @@index([tableroId, estado])
  @@index([creadoAt])
}

model SesionAdmin {
  jti        String    @id
  creadaAt   DateTime  @default(now())
  expiraAt   DateTime
  revocadaAt DateTime?

  @@index([expiraAt])
}

// ─── Suscriptores de correo (Double Opt-In) ───────────────────────────────────
model Subscription {
  id             String    @id @default(cuid())
  email          String    @unique
  nombre         String?
  // PENDING = esperando confirmación | ACTIVE = confirmado | UNSUBSCRIBED = cancelado
  status         String    @default("PENDING")
  // Token único para confirmar y para el enlace de cancelación en cada correo
  token          String    @unique @default(cuid())
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  creadoAt       DateTime  @default(now())

  @@index([status])
  @@index([token])
  @@index([creadoAt])
}

// ─── Registro de envíos masivos (Fase 7 — analítica de audiencia) ─────────────
model EmailEnvio {
  id            String       @id @default(cuid())
  asunto        String
  publicacionId String?
  publicacion   Publicacion? @relation(fields: [publicacionId], references: [id], onDelete: SetNull)
  totalEnviados Int          @default(0)
  totalAbiertos Int          @default(0)
  creadoAt      DateTime     @default(now())

  @@index([publicacionId])
  @@index([creadoAt])
}

// ─── Donaciones — PayPal Orders API v2 (sesión 11) ────────────────────────────
model Donacion {
  id        String   @id @default(cuid())
  monto     Int      // en centavos (ej: 500 = $5.00)
  moneda    String   @default("USD")
  nombre    String?
  correo    String?
  // Order ID que devuelve PayPal al crear la orden. Campo histórico llamado
  // stripeId por compatibilidad con código legacy; conceptualmente es el ID
  // del proveedor de pago (hoy siempre PayPal).
  stripeId  String?  @unique
  estado    String   @default("PENDIENTE") // PENDIENTE | COMPLETADO | FALLIDO | CANCELADO
  creadoAt  DateTime @default(now())

  @@index([estado])
  @@index([creadoAt])
}

// ─── Pedidos de contenido premium ─────────────────────────────────────────────
// Cuando alguien compra acceso a un artículo premium, se crea un PedidoContenido.
// Al completar el pago vía webhook PayPal, su tokenAcceso se vuelve válido para
// abrir el artículo desde un enlace mágico enviado por correo.
model PedidoContenido {
  id              String   @id @default(cuid())
  publicacionId   String
  publicacion     Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  emailComprador  String
  nombreComprador String?
  montoCentavos   Int
  moneda          String   @default("USD")
  paypalOrderId   String?  @unique
  estado          String   @default("PENDIENTE") // PENDIENTE | COMPLETADO | CANCELADO | FALLIDO
  tokenAcceso     String   @unique @default(cuid())
  ipHash          String?
  creadoAt        DateTime @default(now())
  completadoAt    DateTime?
  ultimoAccesoAt  DateTime?
  expiraAccesoAt  DateTime? // caducidad de la LECTURA. null = legacy (sin caducidad). No hay archivo, por eso no hay tope de descargas.

  @@index([emailComprador])
  @@index([estado])
  @@index([publicacionId, estado])
  @@index([creadoAt])
}

// ─── Webhooks procesados — idempotencia para evitar doble-aplicar eventos ─────
// PayPal puede reenviar el mismo evento varias veces. Antes de aplicar uno,
// intentamos insertar su eventId aquí; si ya existe, lo ignoramos.
model WebhookEventoProcesado {
  eventId     String   @id
  proveedor   String   // "paypal"
  tipoEvento  String?  // "PAYMENT.CAPTURE.COMPLETED", etc.
  procesadoAt DateTime @default(now())

  @@index([procesadoAt])
}

// ─── Libros ───────────────────────────────────────────────────────────────────
model Libro {
  id             String          @id @default(cuid())
  titulo         String
  slug           String          @unique
  descripcion    String
  paginas        Int?
  precioCentavos Int?            // null = sin precio; 0 = gratis; >0 = precio en USD
  urlPdf         String
  imagenPortada  String?
  publicado      Boolean         @default(false)
  creadoAt       DateTime        @default(now())
  actualizadoAt  DateTime        @updatedAt
  descargas      DescargaLibro[]
  pedidos        PedidoLibro[]

  @@index([publicado])
  @@index([creadoAt])
}

model DescargaLibro {
  id          String   @id @default(cuid())
  libroId     String
  libro       Libro    @relation(fields: [libroId], references: [id], onDelete: Cascade)
  creadoAt    DateTime @default(now())
  pais        String?
  dispositivo String?

  @@index([libroId])
  @@index([creadoAt])
}

model PedidoLibro {
  id              String    @id @default(cuid())
  libroId         String
  libro           Libro     @relation(fields: [libroId], references: [id], onDelete: Cascade)
  emailComprador  String
  nombreComprador String?
  montoCentavos   Int
  moneda          String    @default("USD")
  paypalOrderId   String?   @unique
  estado          String    @default("PENDIENTE") // PENDIENTE | COMPLETADO | CANCELADO | FALLIDO
  tokenAcceso     String    @unique @default(cuid())
  creadoAt        DateTime  @default(now())
  completadoAt    DateTime?
  ultimoAccesoAt  DateTime?
  descargas       Int       @default(0) // nº de descargas consumidas (tope anti-reshare)
  expiraAccesoAt  DateTime? // caducidad del acceso. null = legacy (sin caducidad)

  @@index([emailComprador])
  @@index([estado])
  @@index([libroId, estado])
  @@index([creadoAt])
}

// Novedades del panel lateral de la home (sesión 27): anuncios curados que
// redirigen a artículos académicos externos, avisos de conferencias, etc.
// Auto-caducan por `expiraAt` para no saturar la home. Se administran desde
// /admin/novedades. RLS habilitado sin políticas (deny-by-default): la app
// las lee/escribe vía Prisma, nunca con la anon key.
model Novedad {
  id         String    @id @default(cuid())
  titulo     String
  textoCorto String?   // descripción breve opcional
  url        String    // destino externo (redirección)
  tipo       String    @default("articulo") // articulo | conferencia | aviso
  activo     Boolean   @default(true)
  orden      Int       @default(0)
  expiraAt   DateTime? // null = no caduca; si pasa, deja de mostrarse
  creadoAt   DateTime  @default(now())

  @@index([activo, expiraAt])
  @@index([orden])
}
