generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Publicacion {
  id            String    @id @default(cuid())
  titulo        String
  slug          String    @unique
  resumen       String
  contenido     String
  publicado     Boolean   @default(false)
  creadoAt      DateTime  @default(now())
  actualizadoAt DateTime  @updatedAt
  publicadoAt   DateTime?

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  etiquetas   PublicacionEtiqueta[]
  comentarios Comentario[]
  reacciones  Reaccion[]
  vistas      VistaPublicacion[]
  descargas   DescargaPdf[]
}

model Categoria {
  id            String        @id @default(cuid())
  nombre        String        @unique
  slug          String        @unique
  descripcion   String?
  publicaciones Publicacion[]
}

model Etiqueta {
  id            String                @id @default(cuid())
  nombre        String                @unique
  slug          String                @unique
  publicaciones PublicacionEtiqueta[]
}

model PublicacionEtiqueta {
  publicacionId String
  etiquetaId    String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  etiqueta      Etiqueta    @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([publicacionId, etiquetaId])
}

model Comentario {
  id            String       @id @default(cuid())
  contenido     String
  autorNombre   String
  publicacionId String
  creadoAt      DateTime     @default(now())
  actualizadoAt DateTime     @updatedAt
  // Anidación
  parentId      String?
  parent        Comentario?  @relation("Respuestas", fields: [parentId], references: [id], onDelete: Cascade)
  respuestas    Comentario[] @relation("Respuestas")
  profundidad   Int          @default(0) // 0=raíz, 1=respuesta, 2=respuesta a respuesta
  // Autor
  esAdmin       Boolean      @default(false)
  // Moderación
  estado        String       @default("VISIBLE") // VISIBLE | OCULTO | ELIMINADO

  publicacion   Publicacion  @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@index([publicacionId])
  @@index([parentId])
  @@index([estado])
}

model Reaccion {
  id            String      @id @default(cuid())
  tipo          String
  publicacionId String
  sessionId     String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@unique([publicacionId, sessionId, tipo])
}

model VistaPublicacion {
  id            String      @id @default(cuid())
  publicacionId String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  pais          String?
  dispositivo   String?
  ipHash        String?
  creadoAt      DateTime    @default(now())

  @@index([publicacionId])
  @@index([creadoAt])
  @@index([pais])
  @@index([ipHash])
}

model VistaRecurso {
  id         String      @id @default(cuid())
  recursoId  String
  recurso    RecursoHtml @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  pais       String?
  dispositivo String?
  ipHash     String?
  creadoAt   DateTime    @default(now())

  @@index([recursoId])
  @@index([creadoAt])
  @@index([ipHash])
}

model VistaComic {
  id          String   @id @default(cuid())
  comicId     String
  comic       Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  pais        String?
  dispositivo String?
  ipHash      String?
  creadoAt    DateTime @default(now())

  @@index([comicId])
  @@index([creadoAt])
  @@index([ipHash])
}

model DescargaPdf {
  id            String      @id @default(cuid())
  publicacionId String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  pais          String?
  creadoAt      DateTime    @default(now())

  @@index([publicacionId])
  @@index([creadoAt])
}

model RecursoHtml {
  id            String         @id @default(cuid())
  titulo        String
  slug          String         @unique
  descripcion   String
  contenido     String
  publicado     Boolean        @default(false)
  creadoAt      DateTime       @default(now())
  actualizadoAt DateTime       @updatedAt
  vistas        VistaRecurso[]

  @@index([slug])
}

model Comic {
  id            String        @id @default(cuid())
  titulo        String
  slug          String        @unique
  descripcion   String
  publicado     Boolean       @default(false)
  creadoAt      DateTime      @default(now())
  actualizadoAt DateTime      @updatedAt
  paginas       PaginaComic[]
  vistas        VistaComic[]

  @@index([slug])
}

model PaginaComic {
  id       String  @id @default(cuid())
  comicId  String
  comic    Comic   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  imageUrl String
  orden    Int
  caption  String?

  @@index([comicId])
  @@index([comicId, orden])
}

// Registro persistente de eventos de seguridad
model EventoSeguridad {
  id       String   @id @default(cuid())
  tipo     String   // LOGIN_FALLIDO | RATE_LIMIT | BOT_DETECTADO | ACCESO_DENEGADO | SPAM | SCAN_PATH
  ip       String
  ruta     String?
  detalles String?
  creadoAt DateTime @default(now())

  @@index([tipo])
  @@index([ip])
  @@index([creadoAt])
}

// Rate limiting persistente (sobrevive cold starts en serverless)
model RateLimitDb {
  id             String    @id @default(cuid())
  clave          String    @unique // "ip:ruta"
  contador       Int       @default(1)
  resetAt        DateTime
  bloqueadoHasta DateTime?

  @@index([clave])
  @@index([resetAt])
}

// Servicios de consultoría
model Servicio {
  id            String                @id @default(cuid())
  titulo        String
  slug          String                @unique
  descripcion   String
  detalle       String?
  categoria     String
  icono         String?
  activo        Boolean               @default(true)
  orden         Int                   @default(0)
  creadoAt      DateTime              @default(now())
  actualizadoAt DateTime              @updatedAt
  cotizaciones  SolicitudCotizacion[]

  @@index([activo])
  @@index([orden])
  @@index([categoria])
}

// Solicitudes de cotización
model SolicitudCotizacion {
  id           String    @id @default(cuid())
  nombre       String
  correo       String
  organizacion String?
  servicioId   String?
  servicio     Servicio? @relation(fields: [servicioId], references: [id], onDelete: SetNull)
  tipoServicio String?
  descripcion  String
  presupuesto  String?
  estado       String    @default("PENDIENTE") // PENDIENTE | REVISADO | ARCHIVADO
  ipHash       String?
  creadoAt     DateTime  @default(now())

  @@index([servicioId])
  @@index([estado])
  @@index([creadoAt])
}

model SesionAdmin {
  jti        String    @id
  creadaAt   DateTime  @default(now())
  expiraAt   DateTime
  revocadaAt DateTime?

  @@index([expiraAt])
}
